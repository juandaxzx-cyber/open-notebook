# Atenea production deploy — environment template (PR-BT4).
#
# Copy to `.env` on the VPS and fill in real values:
#   cp .env.production.example .env
# Then: docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build
#
# This file lists VARIABLE NAMES ONLY, never real values (AGENTS.md hard
# rule #4 / credentials policy) — mirrors the relevant subset of
# .env.example, with production-posture comments where the safe default
# for local dev is NOT the safe default for a publicly reachable box.

# =============================================================================
# REQUIRED
# =============================================================================

# Encrypts API credentials stored in the database. Use a long random
# string (e.g. `openssl rand -hex 32`) — the local-dev placeholder in
# .env.example is not acceptable here.
OPEN_NOTEBOOK_ENCRYPTION_KEY=

# =============================================================================
# DATABASE — SurrealDB is not published by the prod overlay (ports: !reset
# []); it is only reachable from other containers on the compose network.
# Still: root:root (the local-dev default) must NOT be used in production —
# anyone who reaches the container network reaches SurrealDB with it.
# =============================================================================

SURREAL_USER=
# Use a strong, generated password — this is the one credential the whole
# stack's data (learner profiles, sessions, private sources) sits behind.
SURREAL_PASSWORD=
SURREAL_NAMESPACE=
SURREAL_DATABASE=
# Separate SurrealDB database the tutor uses in the same instance (PR-C1);
# default `atenea` is fine to keep.
TUTOR_SURREAL_DATABASE=

# =============================================================================
# REVERSE PROXY / TLS (PR-BT4)
# =============================================================================

# Public domain name, DNS A record already pointing at this VPS. Caddy
# reads this (Caddyfile: {$TUTOR_DOMAIN}) to serve the site and provision
# TLS automatically.
TUTOR_DOMAIN=
# Base URL testers' magic links are built from (PR-BT2 `tutor.access
# create`) — must be the public https URL, not localhost, once BT4 is live.
TUTOR_PUBLIC_URL=

# =============================================================================
# ACCESS CONTROL (PR-BT1 / PR-BT2)
# =============================================================================

# MUST be true in production: gates per-request identity (magic-link
# tokens). false is the single-tenant local-dev default and would leave
# every betatester sharing one account/profile.
TUTOR_AUTH_ENABLED=true
# Per-user daily turn cap (0 = unlimited — not recommended once real
# testers hold the link). Also the cost-control lever for provider spend.
TUTOR_DAILY_TURN_CAP=

# =============================================================================
# LLM PROVIDER (Feature B) — API key comes from the provider's own
# standard env var, never a TUTOR_*-prefixed one.
# =============================================================================

TUTOR_LLM_PROVIDER=
TUTOR_LLM_MODEL=
# Uncomment whichever provider TUTOR_LLM_PROVIDER selects:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# GROQ_API_KEY=

# =============================================================================
# VERIFICATION (PR-G2 memory verification + PR-W1 per-turn verification) —
# should be a DIFFERENT model family than TUTOR_LLM_* (self-verification is
# biased); unset falls back to the generator model with a same-family
# warning, which is not the production posture you want.
# =============================================================================

TUTOR_VERIFIER_PROVIDER=
TUTOR_VERIFIER_MODEL=
# Per-turn verification scope: off|grounded|all — keep the signed-off
# default (grounded) unless the developer changes it.
TUTOR_VERIFY_TURNS=grounded
# Escalation depth: high|cheap — "cheap" trades accuracy for cost/latency
# and surfaces a standing caveat to learners; "high" is the default posture.
TUTOR_VERIFY_PROFILE=high

# =============================================================================
# Everything above is passed into the tutor and caddy containers via
# env_file: .env (docker-compose.yml / docker-compose.prod.yml). Service-
# to-service URLs (SURREAL_URL, OPEN_NOTEBOOK_API_URL) are pinned by
# compose itself and do not belong in this file.
# =============================================================================
